# =========================
# Global ignore for workspace
# =========================

# Python bytecode / cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/

# Build / packaging
build/
dist/
site/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Test / lint / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# Logs / runtime files
*.log
*.out
*.err
*.pid

# Environment / secrets
.env
.env.*
!.env.example
*.pem
*.key

# IDE / editor
.vscode/
.idea/
*.iml

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Node (if any subproject uses JS/TS)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

*.tar.gz